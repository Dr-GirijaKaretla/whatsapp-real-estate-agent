# ─────────────────────────────────────────────────────────
#  WhatsApp Real Estate Agent — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── Anthropic (Claude AI) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6          # or claude-opus-4-7

# ── Twilio WhatsApp ───────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886     # Your Twilio WhatsApp-enabled number

# ── Database ──────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./real_estate.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/real_estate_db

# ── Agency Info ───────────────────────────────────────────
AGENCY_NAME=Your Real Estate Agency
AGENCY_PHONE=+1 (800) 000-0000
AGENCY_EMAIL=info@youragency.com
AGENCY_WEBSITE=https://www.youragency.com

# ── Admin Access ──────────────────────────────────────────
# Comma-separated E.164 phone numbers of business owners / agents
# who get admin commands in WhatsApp
ADMIN_PHONES=+12125551234,+14155551234

# ── App Config ────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false

# ── Security ──────────────────────────────────────────────
# Set to true ONLY during local development (skips Twilio signature check)
SKIP_TWILIO_VALIDATION=false
